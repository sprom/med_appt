# Backend Server Environment Variables

# Server Configuration
NODE_ENV=production
PORT=3000
SERVER_HOST=localhost

# Database
DATABASE_URL=mongodb://localhost:27017/stayhealthy
DATABASE_NAME=stayhealthy

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_REFRESH_EXPIRATION=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5174
CORS_CREDENTIALS=true

# Frontend URL
FRONTEND_URL=http://localhost:5174

# Email Configuration (for notifications)
EMAIL_SERVICE=gmail
EMAIL_USER=noreply@stayhealthy.com
EMAIL_PASSWORD=your_email_password_here
EMAIL_FROM=StayHealthy <noreply@stayhealthy.com>

# API Configuration
API_VERSION=v1
API_PREFIX=/api
API_RATE_LIMIT=100
API_TIMEOUT=30000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Session Configuration
SESSION_SECRET=your_session_secret_here
SESSION_EXPIRATION=24h

# Stripe (for payments - optional)
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key_here

# AWS S3 (for file uploads - optional)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=stayhealthy-uploads

# Feature Flags
ENABLE_2FA=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_APPOINTMENT_REMINDERS=true
ENABLE_SMS_NOTIFICATIONS=false

# Debug Mode
DEBUG=false
DEBUG_SQL=false

# Security
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=15m

# Monitoring
SENTRY_DSN=https://your_sentry_dns_here
DATADOG_API_KEY=your_datadog_api_key

# Cache Configuration
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png,gif

# Timezone
TIMEZONE=UTC

# Version
APP_VERSION=1.0.0
BUILD_NUMBER=001
